# Kopieer dit bestand naar ".env" en vul eigen waarden in voor je het stack start.
INFLUX_PASSWORD=kies-een-wachtwoord
INFLUX_TOKEN=kies-een-lange-random-token
GRAFANA_PASSWORD=kies-een-wachtwoord
# Naam/jaar van deze editie, bijv. "2027". Zo blijven meerdere jaren data
# naast elkaar bestaan in dezelfde InfluxDB-bucket en kun je ze vergelijken.
EVENT_EDITION=2027
# Testmodus (Testdata-tabblad, simulator, meetdata wissen) heeft geen eigen instelling hier — start
# de stack met "docker compose --profile test up -d" om 'm aan te zetten, en met het gewone
# "docker compose up -d" (zonder --profile test) om 'm weer uit te zetten voor een echt evenement.
